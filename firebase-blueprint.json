{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product listed in the store with affiliate links.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "description": "Product category" },
        "price": { "type": "string", "description": "Current price" },
        "amazonUrl": { "type": "string", "description": "Affiliate link" },
        "image": { "type": "string", "description": "Product image URL" },
        "description": { "type": "string", "description": "Detailed review/description" },
        "benefit": { "type": "string", "description": "Short benefit highlight" },
        "rating": { "type": "number", "description": "Star rating (0-5)" },
        "reviewsCount": { "type": "number", "description": "Number of reviews" },
        "isTrending": { "type": "boolean" },
        "isDeal": { "type": "boolean" },
        "pros": { "type": "array", "items": { "type": "string" } },
        "cons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "category", "price", "amazonUrl", "image", "description"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the store.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available in the store."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
